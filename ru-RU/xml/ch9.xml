            <speak chara="einNoFace">..................</speak>
            <show chara="einBagaVestClose-up" position="center"/>
            <speak chara="einNoFace">Вельт, скажи... почему она вдруг затихла?</speak>
            <end post="U2FsdGVkX19e4WHxF4Pk4HxRATs2"/>
